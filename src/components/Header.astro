---
const { transparent = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(base, "") || "/";
const isActive = (p: string) => path === p || (p !== "/" && path.startsWith(p));
const url = (p: string) => `${base}${p}`;

// Color tokens for the two states.
// When transparent (over hero video): light text + gold accent
// When scrolled (over cream-soft bg): dark text + gold-deep accent
const logoCls = transparent ? "text-cream" : "text-ink";
const logoAccentCls = transparent ? "text-gold-light" : "text-gold-deep";
const navCls = transparent ? "text-cream/90" : "text-ink/80";
const navHoverCls = transparent ? "hover:text-gold-light" : "hover:text-gold-deep";
const activeCls = transparent ? "text-gold-light font-semibold" : "text-gold-deep font-semibold";
const btnBgCls = transparent ? "bg-gold text-ink hover:bg-cream" : "bg-gold-deep text-cream hover:bg-ink";
const burgerCls = transparent ? "text-cream" : "text-ink";
---

<header
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    transparent ? "bg-gradient-to-b from-ink/55 via-ink/30 to-transparent" : "bg-cream-soft/95 backdrop-blur border-b border-line",
  ]}
  data-header
  data-transparent={transparent ? "1" : "0"}
>
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between">
    <a href={url("/")} class={`font-display text-xl sm:text-2xl tracking-wide ${logoCls}`} data-logo>
      Scott's <span class={`italic ${logoAccentCls}`} data-logo-accent>Hospitality</span>
    </a>

    <nav class={`hidden lg:flex items-center gap-8 text-sm tracking-wider uppercase ${navCls}`} data-nav>
      <a href="https://squidly-inc.github.io/scotts-mockup/" class={`${navHoverCls} transition`}>Restaurant</a>
      <a href="https://squidly-inc.github.io/scotts-ballroom/" class={`${navHoverCls} transition`}>Ballroom</a>
      <a href="https://squidly-inc.github.io/scotts-provisions/" class={`${navHoverCls} transition`}>Provisions</a>
      <a href="https://squidly-inc.github.io/scotts-social-club/" class={`${navHoverCls} transition`}>Social Club</a>
      <a href={url("/our-story")} class:list={[`${navHoverCls} transition`, isActive("/our-story") && activeCls]}>Our Story</a>
    </nav>

    <a href={url("/contact")} class:list={[`hidden lg:inline-block text-xs font-semibold uppercase tracking-widest px-5 py-2.5 transition`, btnBgCls]} data-cta>
      Contact
    </a>

    <button data-mobile-toggle class={`lg:hidden p-2 ${burgerCls}`} aria-label="Open menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
    </button>
  </div>

  <div data-mobile-menu class="hidden lg:hidden bg-cream text-ink border-t border-line">
    <nav class="flex flex-col px-5 py-6 gap-1 text-sm uppercase tracking-wider">
      <a href="https://squidly-inc.github.io/scotts-mockup/" class="py-3 border-b border-line hover:text-gold-deep">Restaurant</a>
      <a href="https://squidly-inc.github.io/scotts-ballroom/" class="py-3 border-b border-line hover:text-gold-deep">Ballroom</a>
      <a href="https://squidly-inc.github.io/scotts-provisions/" class="py-3 border-b border-line hover:text-gold-deep">Provisions</a>
      <a href="https://squidly-inc.github.io/scotts-social-club/" class="py-3 border-b border-line hover:text-gold-deep">Social Club</a>
      <a href={url("/our-story")} class="py-3 border-b border-line hover:text-gold-deep">Our Story</a>
      <a href={url("/contact")} class="py-3 hover:text-gold-deep">Contact</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-mobile-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));

  const header = document.querySelector("[data-header]") as HTMLElement | null;
  const startedTransparent = header?.getAttribute("data-transparent") === "1";

  if (header && startedTransparent) {
    const logo = header.querySelector("[data-logo]") as HTMLElement | null;
    const logoAccent = header.querySelector("[data-logo-accent]") as HTMLElement | null;
    const nav = header.querySelector("[data-nav]") as HTMLElement | null;
    const cta = header.querySelector("[data-cta]") as HTMLElement | null;
    const burger = header.querySelector("[data-mobile-toggle]") as HTMLElement | null;

    const setScrolled = (scrolled: boolean) => {
      // Background
      if (scrolled) {
        header.classList.remove("bg-gradient-to-b", "from-ink/55", "via-ink/30", "to-transparent");
        header.classList.add("bg-cream-soft/95", "backdrop-blur", "border-b", "border-line");
      } else {
        header.classList.add("bg-gradient-to-b", "from-ink/55", "via-ink/30", "to-transparent");
        header.classList.remove("bg-cream-soft/95", "backdrop-blur", "border-b", "border-line");
      }
      // Text colors
      logo?.classList.toggle("text-cream", !scrolled);
      logo?.classList.toggle("text-ink", scrolled);
      logoAccent?.classList.toggle("text-gold-light", !scrolled);
      logoAccent?.classList.toggle("text-gold-deep", scrolled);
      nav?.classList.toggle("text-cream/90", !scrolled);
      nav?.classList.toggle("text-ink/80", scrolled);
      burger?.classList.toggle("text-cream", !scrolled);
      burger?.classList.toggle("text-ink", scrolled);
      // CTA bg swap
      cta?.classList.toggle("bg-gold", !scrolled);
      cta?.classList.toggle("text-ink", !scrolled);
      cta?.classList.toggle("hover:bg-cream", !scrolled);
      cta?.classList.toggle("bg-gold-deep", scrolled);
      cta?.classList.toggle("text-cream", scrolled);
      cta?.classList.toggle("hover:bg-ink", scrolled);
    };

    const onScroll = () => setScrolled(window.scrollY > 60);
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
