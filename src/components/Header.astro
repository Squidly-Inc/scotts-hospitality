---
import { SITES } from "../lib/sites";
const { transparent = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(base, "") || "/";
const isActive = (p: string) => path === p || (p !== "/" && path.startsWith(p));
const url = (p: string) => `${base}${p}`;
---

<header
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    transparent ? "bg-transparent" : "bg-ink/95 backdrop-blur",
  ]}
  data-header
>
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between">
    <a href={url("/")} class="block">
      <img src={url("/scotts-wordmark.png")} alt="Scott's Hospitality" class="w-auto" data-logo />
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm tracking-wider uppercase text-cream/90">
      <a href={`${SITES.restaurant}/`} class="hover:text-gold-light transition">Restaurant</a>
      <a href={`${SITES.ballroom}/`} class="hover:text-gold-light transition">Ballroom</a>
      <a href={`${SITES.provisions}/`} class="hover:text-gold-light transition">Provisions</a>
      <a href={`${SITES.socialClub}/`} class="hover:text-gold-light transition">Social Club</a>
      <a href={url("/our-story")} class:list={["hover:text-gold-light transition", isActive("/our-story") && "text-gold-light"]}>Our Story</a>
    </nav>

    <a
      href={url("/contact")}
      class="hidden lg:inline-block bg-gold text-ink text-xs font-semibold uppercase tracking-widest px-5 py-2.5 hover:bg-cream transition"
    >
      Contact
    </a>

    <button data-mobile-toggle class="lg:hidden text-cream p-2" aria-label="Open menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div data-mobile-menu class="hidden lg:hidden bg-ink text-cream border-t border-cream/10">
    <nav class="flex flex-col px-5 py-6 gap-1 text-sm uppercase tracking-wider">
      <a href={`${SITES.restaurant}/`} class="py-3 border-b border-cream/10 hover:text-gold-light">Restaurant</a>
      <a href={`${SITES.ballroom}/`} class="py-3 border-b border-cream/10 hover:text-gold-light">Ballroom</a>
      <a href={`${SITES.provisions}/`} class="py-3 border-b border-cream/10 hover:text-gold-light">Provisions</a>
      <a href={`${SITES.socialClub}/`} class="py-3 border-b border-cream/10 hover:text-gold-light">Social Club</a>
      <a href={url("/our-story")} class="py-3 border-b border-cream/10 hover:text-gold-light">Our Story</a>
      <a href={url("/contact")} class="mt-4 bg-gold text-ink text-center font-semibold py-3 hover:bg-cream transition">Contact</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-mobile-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));

  const header = document.querySelector("[data-header]") as HTMLElement | null;
  if (header && header.classList.contains("bg-transparent")) {
    const onScroll = () => {
      if (window.scrollY > 60) {
        header.classList.remove("bg-transparent");
        header.classList.add("bg-ink/95", "backdrop-blur");
      } else {
        header.classList.add("bg-transparent");
        header.classList.remove("bg-ink/95", "backdrop-blur");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>

<style is:global>
  /* Logo is oversized at the top of the page and eases down to the standard
     nav height once the visitor scrolls (see header-scrolled toggle). */
  [data-logo] {
    height: 4rem;
    transition: height 0.3s ease;
  }
  @media (min-width: 640px) {
    [data-logo] { height: 4.75rem; }
  }
  .header-scrolled [data-logo] { height: 3rem; }
  @media (min-width: 640px) {
    .header-scrolled [data-logo] { height: 3.5rem; }
  }
</style>

<script>
  const shrinkHeader = document.querySelector("[data-header]");
  const applyShrink = () => shrinkHeader?.classList.toggle("header-scrolled", window.scrollY > 60);
  applyShrink();
  document.addEventListener("scroll", applyShrink, { passive: true });
</script>
