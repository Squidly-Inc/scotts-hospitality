---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const url = (p: string) => `${base}${p}`;
---

<footer class="bg-ink text-cream/85">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-16 grid gap-12 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="font-display text-2xl text-cream mb-3">
        Scott's <span class="italic text-gold-light">Hospitality</span>
      </div>
      <p class="text-sm leading-relaxed text-cream/70 max-w-md">
        A family of hospitality experiences in downtown San Jose — restaurant,
        ballroom, catering, and a private members' club, all under one name.
      </p>
    </div>

    <div>
      <h4 class="text-sm uppercase tracking-widest text-gold-light mb-4">The Scott's San Jose Family</h4>
      <ul class="text-sm space-y-2 text-cream/70">
        <li><a href="https://squidly-inc.github.io/scotts-mockup/" class="hover:text-gold-light">Scott's Seafood San Jose</a></li>
        <li><a href="https://squidly-inc.github.io/scotts-ballroom/" class="hover:text-gold-light">Scott's Ballroom</a></li>
        <li><a href="https://squidly-inc.github.io/scotts-provisions/" class="hover:text-gold-light">Scott's Provisions</a></li>
        <li><a href="https://www.scottssocialclub.com/" class="hover:text-gold-light">Scott's Social Club</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm uppercase tracking-widest text-gold-light mb-4">Reach Us</h4>
      <p class="text-sm leading-relaxed text-cream/70">
        Downtown San Jose<br/>
        Restaurant: 200 S. 1st St<br/>
        Events: 88 S. 4th St, 7th Fl<br/><br/>
        <a href={url("/contact")} class="hover:text-gold-light">Get in touch →</a>
      </p>
    </div>
  </div>

  <div class="border-t border-cream/10 bg-ink-soft">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-8 grid md:grid-cols-2 gap-6 items-center">
      <div>
        <p class="text-gold-light uppercase tracking-widest text-xs mb-2">Newsletter</p>
        <p class="text-cream/80 text-sm leading-snug">One list across the Scott's San Jose family — subscribe once, hear from every concept.</p>
      </div>
      <form
        action="https://scottsseafoodsj.us8.list-manage.com/subscribe/post?u=fab8fe5ff01093f4e48a5bd14&amp;id=e688913a46&amp;f_id=00e736e3f0"
        method="post"
        target="_blank"
        novalidate
        class="flex gap-2"
      >
        <label class="sr-only" for="footer-newsletter">Email address</label>
        <input id="footer-newsletter" name="EMAIL" type="email" required placeholder="you@example.com" class="flex-1 bg-cream-soft text-ink px-4 py-2.5 text-sm placeholder:text-ink/70 focus:outline-none focus:ring-2 focus:ring-gold-light" />
        <div aria-hidden="true" style="position: absolute; left: -5000px;">
          <input type="text" name="b_fab8fe5ff01093f4e48a5bd14_e688913a46" tabindex="-1" value="" />
        </div>
        <button type="submit" name="subscribe" class="bg-gold-light text-ink text-xs font-semibold uppercase tracking-widest px-5 hover:bg-cream transition">Subscribe</button>
      </form>
    </div>
  </div>

  <div class="border-t border-cream/10">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-cream/65">
      <p>© 2026 Scott's Hospitality Group. All rights reserved.</p>
      <div class="flex gap-6">
        <a href={url("/our-story")} class="hover:text-gold-light">Our Story</a>
        <a href={url("/contact")} class="hover:text-gold-light">Contact</a>
        <a href={url("/accessibility")} class="hover:text-gold-light">Accessibility</a>
      </div>
    </div>
  </div>
</footer>
