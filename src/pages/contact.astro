---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | Scott's Hospitality">
  <section class="bg-ink pt-32 pb-12 sm:pb-16">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-gold-light uppercase tracking-[0.3em] text-xs mb-4">Get in Touch</p>
      <h1 class="font-display text-4xl sm:text-6xl text-cream mb-5 leading-tight">
        Reach the right team.
      </h1>
      <p class="text-cream/75 max-w-2xl mx-auto leading-relaxed">
        Tell us what you're planning — we'll route you to the team that handles it.
      </p>
    </div>
  </section>

  <section class="bg-cream-soft py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 grid md:grid-cols-2 gap-6 sm:gap-8">
      <a href="https://squidly-inc.github.io/scotts-mockup/reservations" class="block bg-paper p-8 border-t-4 border-gold hover:shadow-xl transition">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Dining</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Seafood San Jose</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Reservations, private dining, gift cards.</p>
        <p class="text-ink/80 text-sm">
          <a href="tel:+14089711700" class="hover:text-gold-deep block">(408) 971-1700</a>
          <span class="text-ink/60">200 S. 1st Street, San Jose</span>
        </p>
      </a>

      <a href="https://squidly-inc.github.io/scotts-ballroom/contact" class="block bg-paper p-8 border-t-4 border-gold hover:shadow-xl transition">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Events</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Ballroom</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Weddings, galas, corporate events up to 790+.</p>
        <p class="text-ink/80 text-sm">
          <a href="tel:+16693474389" class="hover:text-gold-deep block">(669) 347-4389</a>
          <a href="mailto:kremo.bibi@scottsseafoodsj.com" class="hover:text-gold-deep block">kremo.bibi@scottsseafoodsj.com</a>
          <span class="text-ink/60">88 S. 4th Street, 7th Floor</span>
        </p>
      </a>

      <a href="https://squidly-inc.github.io/scotts-provisions/contact" class="block bg-paper p-8 border-t-4 border-gold hover:shadow-xl transition">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Catering</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Provisions</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Boxed lunches, drop-off catering, full-service events.</p>
        <p class="text-ink/80 text-sm">
          <a href="tel:+16502836307" class="hover:text-gold-deep block">(650) 283-6307</a>
          <span class="text-ink/60">info@scottsprovisions.com</span>
        </p>
      </a>

      <a href="https://squidly-inc.github.io/scotts-social-club/" class="block bg-paper p-8 border-t-4 border-gold hover:shadow-xl transition">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Membership</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Social Club</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Private club membership, networking, events.</p>
        <p class="text-ink/80 text-sm">
          <a href="tel:+14084646992" class="hover:text-gold-deep block">(408) 464-6992</a>
          <span class="text-ink/60">robert.robledo@scottssocialclub.com</span>
        </p>
      </a>
    </div>
  </section>

  <section class="bg-paper py-20 sm:py-24 border-t border-line text-center">
    <div class="max-w-2xl mx-auto px-5 sm:px-8">
      <h2 class="font-display text-2xl sm:text-3xl text-ink mb-4">Not sure who to ask?</h2>
      <p class="text-ink/70 leading-relaxed mb-8">
        Send us a note at the address below and we'll route you to the right team.
      </p>
      <a href="mailto:info@scottshospitality.com" class="font-display text-xl text-gold-deep hover:text-ink transition">
        info@scottshospitality.com
      </a>
    </div>
  </section>

  <section class="bg-ink py-16 sm:py-20">
    <div class="max-w-2xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-gold-light uppercase tracking-[0.3em] text-xs mb-3">Stay in the Loop</p>
      <h2 class="font-display text-2xl sm:text-3xl text-cream mb-3 leading-tight">
        One list. Four concepts.
      </h2>
      <p class="text-cream/70 leading-relaxed mb-7 text-sm">
        Subscribe once and hear from every Scott's San Jose concept — new menus,
        events, openings, and the occasional VIP invite.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input id="newsletter-email" type="email" required placeholder="you@example.com" class="flex-1 bg-cream-soft text-ink px-4 py-3 placeholder:text-ink/40 focus:outline-none focus:ring-2 focus:ring-gold-light" />
        <button type="submit" class="bg-gold-light text-ink text-xs font-semibold uppercase tracking-widest px-6 py-3 hover:bg-cream transition">Subscribe</button>
      </form>
      <p class="text-cream/40 text-xs mt-4">We respect your inbox. No spam, unsubscribe anytime.</p>
    </div>
  </section>
</Layout>
