---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | Scott's Hospitality">
  <section class="bg-ink pt-32 pb-12 sm:pb-16">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-gold-light uppercase tracking-[0.3em] text-xs mb-4">Get in Touch</p>
      <h1 class="font-display text-4xl sm:text-6xl text-cream mb-5 leading-tight">
        Reach the right team.
      </h1>
      <p class="text-cream/75 max-w-2xl mx-auto leading-relaxed">
        Tell us what you're planning — we'll route you to the team that handles it.
      </p>
    </div>
  </section>

  <section class="bg-cream-soft py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 grid md:grid-cols-2 gap-6 sm:gap-8">
      <div class="flex flex-col bg-paper p-8 border-t-4 border-gold">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Dining</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Seafood San Jose</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Reservations, private dining, gift cards.</p>
        <div class="text-ink/80 text-sm space-y-1 mb-5">
          <a href="tel:+14089711700" class="block hover:text-gold-deep">(408) 971-1700</a>
          <a href="mailto:info@scottsseafoodsj.com" class="block hover:text-gold-deep">info@scottsseafoodsj.com</a>
          <p class="text-ink/60">200 S. 1st Street, San Jose</p>
        </div>
        <a href="https://squidly-inc.github.io/scotts-mockup/reservations" class="mt-auto inline-block text-xs uppercase tracking-widest font-semibold text-gold-deep border-b border-gold-deep self-start pb-1 hover:text-ink hover:border-ink transition">
          Visit Scott's Seafood →
        </a>
      </div>

      <div class="flex flex-col bg-paper p-8 border-t-4 border-gold">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Events</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Ballroom</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Weddings, galas, corporate events up to 790+.</p>
        <div class="text-ink/80 text-sm space-y-1 mb-5">
          <a href="tel:+16693474389" class="block hover:text-gold-deep">(669) 347-4389</a>
          <a href="mailto:events@scottsballroom.com" class="block hover:text-gold-deep">events@scottsballroom.com</a>
          <p class="text-ink/60">88 S. 4th Street, 7th Floor</p>
        </div>
        <a href="https://squidly-inc.github.io/scotts-ballroom/contact" class="mt-auto inline-block text-xs uppercase tracking-widest font-semibold text-gold-deep border-b border-gold-deep self-start pb-1 hover:text-ink hover:border-ink transition">
          Visit Scott's Ballroom →
        </a>
      </div>

      <div class="flex flex-col bg-paper p-8 border-t-4 border-gold">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Catering</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Provisions</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Boxed lunches, drop-off catering, full-service events.</p>
        <div class="text-ink/80 text-sm space-y-1 mb-5">
          <a href="tel:+16502836307" class="block hover:text-gold-deep">(650) 283-6307</a>
          <a href="mailto:catering@scottsprovisions.com" class="block hover:text-gold-deep">catering@scottsprovisions.com</a>
        </div>
        <a href="https://squidly-inc.github.io/scotts-provisions/contact" class="mt-auto inline-block text-xs uppercase tracking-widest font-semibold text-gold-deep border-b border-gold-deep self-start pb-1 hover:text-ink hover:border-ink transition">
          Visit Scott's Provisions →
        </a>
      </div>

      <div class="flex flex-col bg-paper p-8 border-t-4 border-gold">
        <p class="text-gold-deep uppercase tracking-widest text-xs mb-2">For Membership</p>
        <h2 class="font-display text-2xl text-ink mb-3">Scott's Social Club</h2>
        <p class="text-ink/70 leading-relaxed mb-5">Private club membership, networking, events.</p>
        <div class="text-ink/80 text-sm space-y-1 mb-5">
          <a href="tel:+14084646992" class="block hover:text-gold-deep">(408) 464-6992</a>
          <a href="mailto:membership@scottssocialclub.com" class="block hover:text-gold-deep">membership@scottssocialclub.com</a>
        </div>
        <a href="https://www.scottssocialclub.com/" class="mt-auto inline-block text-xs uppercase tracking-widest font-semibold text-gold-deep border-b border-gold-deep self-start pb-1 hover:text-ink hover:border-ink transition">
          Visit Scott's Social Club →
        </a>
      </div>
    </div>
  </section>

  <section class="bg-paper py-20 sm:py-24 border-t border-line text-center">
    <div class="max-w-2xl mx-auto px-5 sm:px-8">
      <h2 class="font-display text-2xl sm:text-3xl text-ink mb-4">Not sure who to ask?</h2>
      <p class="text-ink/70 leading-relaxed mb-8">
        Send us a note at the address below and we'll route you to the right team.
      </p>
      <a href="mailto:info@scottshospitality.com" class="font-display text-xl text-gold-deep hover:text-ink transition">
        info@scottshospitality.com
      </a>
    </div>
  </section>

  <section class="bg-ink py-16 sm:py-20">
    <div class="max-w-2xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-gold-light uppercase tracking-[0.3em] text-xs mb-3">Stay in the Loop</p>
      <h2 class="font-display text-2xl sm:text-3xl text-cream mb-3 leading-tight">
        One list. Four concepts.
      </h2>
      <p class="text-cream/70 leading-relaxed mb-7 text-sm">
        Subscribe once and hear from every Scott's San Jose concept — new menus,
        events, openings, and the occasional VIP invite.
      </p>
      <form
        action="https://scottsseafoodsj.us8.list-manage.com/subscribe/post?u=fab8fe5ff01093f4e48a5bd14&amp;id=e688913a46&amp;f_id=00e736e3f0"
        method="post"
        target="_blank"
        novalidate
        class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
      >
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input id="newsletter-email" name="EMAIL" type="email" required placeholder="you@example.com" class="flex-1 bg-cream-soft text-ink px-4 py-3 placeholder:text-ink/40 focus:outline-none focus:ring-2 focus:ring-gold-light" />
        <div aria-hidden="true" style="position: absolute; left: -5000px;">
          <input type="text" name="b_fab8fe5ff01093f4e48a5bd14_e688913a46" tabindex="-1" value="" />
        </div>
        <button type="submit" name="subscribe" class="bg-gold-light text-ink text-xs font-semibold uppercase tracking-widest px-6 py-3 hover:bg-cream transition">Subscribe</button>
      </form>
      <p class="text-cream/60 text-xs mt-4">We respect your inbox. No spam, unsubscribe anytime.</p>
    </div>
  </section>
</Layout>
